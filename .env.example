# Copy this file to ".env" and fill in your values.

# Web3Forms access key (free, get it at https://web3forms.com — enter your email,
# they send you a key). Used by the contact form. Must start with PUBLIC_ so the
# key is available in the browser (Web3Forms access keys are safe to expose).
PUBLIC_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key

# Your production URL (used for SEO / canonical / sitemap).
SITE_URL=https://your-domain.vercel.app
