---
import { Image } from 'astro:assets';
import type { RenderablePhoto } from '../lib/photos';

interface Props {
  href: string;
  name: string;
  blurb: string;
  index: number;
  cover?: RenderablePhoto;
}

const { href, name, blurb, index, cover } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---

<a class="card" href={href}>
  <div class="media">
    {
      cover ? (
        <Image
          src={cover.thumb}
          alt={cover.alt}
          widths={[400, 700, 1000]}
          sizes="(min-width: 720px) 33vw, 100vw"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="placeholder" aria-hidden="true" />
      )
    }
  </div>
  <div class="meta">
    <span class="num label">{num}</span>
    <h3 class="name">{name}</h3>
    <p class="blurb">{blurb}</p>
    <span class="cta label">View work →</span>
  </div>
</a>

<style>
  .card {
    display: block;
  }
  .media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--bg-elev);
  }
  .media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease), filter 0.5s var(--ease);
    filter: grayscale(0.15) brightness(0.95);
  }
  .card:hover .media :global(img) {
    transform: scale(1.04);
    filter: grayscale(0) brightness(1);
  }
  .placeholder {
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(
      45deg,
      var(--bg-elev),
      var(--bg-elev) 12px,
      #1b1b1e 12px,
      #1b1b1e 24px
    );
  }
  .meta {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding-top: 1rem;
  }
  .num {
    color: var(--accent);
  }
  .name {
    font-size: clamp(1.4rem, 2.6vw, 1.9rem);
  }
  .blurb {
    color: var(--muted);
    margin: 0;
    max-width: 34ch;
  }
  .cta {
    color: var(--fg);
    margin-top: 0.3rem;
    transition: color 0.25s var(--ease);
  }
  .card:hover .cta {
    color: var(--accent);
  }
</style>
