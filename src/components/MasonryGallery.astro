---
import { Image, getImage } from 'astro:assets';
import type { RenderablePhoto } from '../lib/photos';
import type { SubTag } from '../lib/categories';

interface Props {
  photos: RenderablePhoto[];
  /** When provided, renders filter tabs (used by the portraits page). */
  subtags?: SubTag[];
  galleryId?: string;
}

const { photos, subtags, galleryId = 'gallery' } = Astro.props;

// Pre-generate optimized WebP "large" images for the lightbox so the overlay
// loads a properly sized, modern-format file instead of the raw master.
const slides = await Promise.all(
  photos.map(async (p) => {
    const img = await getImage({
      src: p.large,
      widths: [800, 1200, 1600, 2000],
      format: 'webp',
      quality: 82,
    });
    return {
      src: img.src,
      srcset: img.srcSet.attribute,
      sizes: '(min-width: 1200px) 1100px, 92vw',
      w: p.large.width,
      h: p.large.height,
      alt: p.alt,
      title: p.title ?? '',
      subtag: p.subtag ?? '',
    };
  }),
);
---

<section class="gallery" data-gallery id={galleryId}>
  {
    subtags && photos.length > 0 && (
      <div class="tabs" role="tablist" aria-label="Filter by sub-category">
        <button class="tab" type="button" role="tab" data-filter="all" aria-selected="true">
          All
        </button>
        {subtags.map((s) => (
          <button class="tab" type="button" role="tab" data-filter={s.slug} aria-selected="false">
            {s.name}
          </button>
        ))}
      </div>
    )
  }

  {
    photos.length === 0 ? (
      <p class="empty">
        No photos yet. Drop images into <code>src/photos/</code> and register them in
        <code>src/data/photos.json</code> to see them here.
      </p>
    ) : (
      <ul class="masonry" data-masonry>
        {photos.map((p, i) => (
          <li class="masonry-item" data-subtag={p.subtag ?? ''}>
            <button
              class="thumb-btn"
              type="button"
              data-index={i}
              aria-label={`View larger: ${p.title || p.alt}`}
            >
              <Image
                src={p.thumb}
                alt={p.alt}
                widths={[300, 450, 700]}
                sizes="(min-width: 1100px) 25vw, (min-width: 700px) 33vw, 50vw"
                loading="lazy"
                decoding="async"
              />
              {p.title && <span class="cap">{p.title}</span>}
            </button>
          </li>
        ))}
      </ul>
    )
  }

  <!-- slide data for the lightbox -->
  <script type="application/json" data-slides set:html={JSON.stringify(slides)} is:inline
  ></script>

  <!-- lightbox overlay -->
  <div class="lightbox" data-lightbox hidden aria-hidden="true">
    <div class="lb-backdrop" data-lb-close></div>
    <div class="lb-stage" role="dialog" aria-modal="true" aria-label="Image viewer">
      <figure class="lb-figure">
        <img class="lb-img" data-lb-img alt="" decoding="async" />
        <figcaption class="lb-caption" data-lb-caption></figcaption>
      </figure>
      <button class="lb-btn lb-prev" type="button" data-lb-prev aria-label="Previous (←)">‹</button>
      <button class="lb-btn lb-next" type="button" data-lb-next aria-label="Next (→)">›</button>
      <button class="lb-btn lb-close" type="button" data-lb-close-btn aria-label="Close (Esc)">✕</button>
      <div class="lb-counter" data-lb-counter aria-hidden="true"></div>
    </div>
  </div>
</section>

<style>
  .gallery {
    --grid-gap: clamp(0.6rem, 1.6vw, 1.4rem);
  }

  /* ── filter tabs ──────────────────────────────────────────────────────── */
  .tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: clamp(1.4rem, 3vw, 2.4rem);
  }
  .tab {
    font: inherit;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: var(--muted);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.55em 1.15em;
    cursor: pointer;
    transition: color 0.2s var(--ease), border-color 0.2s var(--ease),
      background 0.2s var(--ease);
  }
  .tab:hover {
    color: var(--fg-strong);
    border-color: var(--line-strong);
  }
  .tab[aria-selected='true'] {
    color: var(--bg);
    background: var(--fg-strong);
    border-color: var(--fg-strong);
  }

  /* ── masonry grid (CSS columns) ───────────────────────────────────────── */
  .masonry {
    list-style: none;
    margin: 0;
    padding: 0;
    column-count: 2;
    column-gap: var(--grid-gap);
  }
  @media (min-width: 700px) {
    .masonry {
      column-count: 3;
    }
  }
  @media (min-width: 1100px) {
    .masonry {
      column-count: 4;
    }
  }
  .masonry-item {
    break-inside: avoid;
    margin-bottom: var(--grid-gap);
  }
  .masonry-item[hidden] {
    display: none;
  }

  .thumb-btn {
    position: relative;
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: var(--bg-elev);
    cursor: zoom-in;
    overflow: hidden;
  }
  .thumb-btn :global(img) {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.6s var(--ease), filter 0.4s var(--ease),
      opacity 0.4s var(--ease);
    filter: grayscale(0.12);
  }
  .thumb-btn:hover :global(img) {
    transform: scale(1.035);
    filter: grayscale(0);
  }
  .cap {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 1.6rem 0.9rem 0.7rem;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: #fff;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s var(--ease), transform 0.3s var(--ease);
    pointer-events: none;
  }
  .thumb-btn:hover .cap,
  .thumb-btn:focus-visible .cap {
    opacity: 1;
    transform: translateY(0);
  }

  .empty {
    color: var(--muted);
    border: 1px dashed var(--line);
    padding: 2rem;
    border-radius: 10px;
  }
  .empty code {
    color: var(--fg);
  }

  /* ── lightbox ─────────────────────────────────────────────────────────── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lightbox[hidden] {
    display: none;
  }
  .lb-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(7, 7, 8, 0.94);
    backdrop-filter: blur(4px);
    cursor: zoom-out;
    animation: lb-fade 0.25s var(--ease);
  }
  .lb-stage {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(0.8rem, 4vw, 3rem);
    pointer-events: none;
  }
  .lb-figure {
    margin: 0;
    max-width: min(1100px, 94vw);
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: auto;
    animation: lb-pop 0.3s var(--ease);
  }
  .lb-img {
    max-width: 100%;
    max-height: 82vh;
    width: auto;
    height: auto;
    object-fit: contain;
    background: #111;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
  }
  .lb-caption {
    margin-top: 0.9rem;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    text-align: center;
    min-height: 1em;
  }
  .lb-btn {
    position: absolute;
    pointer-events: auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.2s var(--ease), border-color 0.2s var(--ease),
      transform 0.2s var(--ease);
  }
  .lb-btn:hover {
    background: rgba(255, 255, 255, 0.16);
    border-color: rgba(255, 255, 255, 0.4);
  }
  .lb-prev,
  .lb-next {
    top: 50%;
    transform: translateY(-50%);
    width: 52px;
    height: 52px;
    font-size: 1.7rem;
    line-height: 1;
  }
  .lb-prev {
    left: clamp(0.6rem, 2vw, 2rem);
  }
  .lb-next {
    right: clamp(0.6rem, 2vw, 2rem);
  }
  .lb-close {
    top: clamp(0.8rem, 2.4vw, 1.8rem);
    right: clamp(0.8rem, 2.4vw, 1.8rem);
    width: 44px;
    height: 44px;
    font-size: 1.05rem;
  }
  .lb-counter {
    position: absolute;
    bottom: clamp(0.8rem, 2.4vw, 1.6rem);
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    color: var(--muted);
  }

  @keyframes lb-fade {
    from {
      opacity: 0;
    }
  }
  @keyframes lb-pop {
    from {
      opacity: 0;
      transform: scale(0.98);
    }
  }

  @media (max-width: 560px) {
    .lb-prev,
    .lb-next {
      width: 44px;
      height: 44px;
      font-size: 1.4rem;
    }
  }
</style>

<script>
  interface Slide {
    src: string;
    srcset: string;
    sizes: string;
    w: number;
    h: number;
    alt: string;
    title: string;
    subtag: string;
  }

  function initGallery(root: HTMLElement) {
    const dataEl = root.querySelector<HTMLScriptElement>('[data-slides]');
    if (!dataEl) return;
    const slides: Slide[] = JSON.parse(dataEl.textContent || '[]');

    const items = Array.from(
      root.querySelectorAll<HTMLLIElement>('.masonry-item'),
    );
    const buttons = Array.from(
      root.querySelectorAll<HTMLButtonElement>('.thumb-btn'),
    );
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('.tab'));

    const lb = root.querySelector<HTMLElement>('[data-lightbox]');
    const lbImg = root.querySelector<HTMLImageElement>('[data-lb-img]');
    const lbCaption = root.querySelector<HTMLElement>('[data-lb-caption]');
    const lbCounter = root.querySelector<HTMLElement>('[data-lb-counter]');
    if (!lb || !lbImg || !lbCaption || !lbCounter) return;

    let current = 0; // index into `slides`
    let lastFocused: HTMLElement | null = null;

    // ── filtering ──────────────────────────────────────────────────────
    function visibleIndexes(): number[] {
      return buttons
        .filter((b) => !(b.closest('.masonry-item') as HTMLElement)?.hidden)
        .map((b) => Number(b.dataset.index));
    }

    function applyFilter(filter: string) {
      items.forEach((item) => {
        const show = filter === 'all' || item.dataset.subtag === filter;
        item.hidden = !show;
      });
      tabs.forEach((t) =>
        t.setAttribute('aria-selected', String(t.dataset.filter === filter)),
      );
    }

    tabs.forEach((tab) =>
      tab.addEventListener('click', () => applyFilter(tab.dataset.filter || 'all')),
    );

    // ── lightbox ───────────────────────────────────────────────────────
    function render() {
      const s = slides[current];
      if (!s) return;
      lbImg.src = s.src;
      lbImg.srcset = s.srcset;
      lbImg.sizes = s.sizes;
      lbImg.alt = s.alt;
      lbImg.width = s.w;
      lbImg.height = s.h;
      lbCaption.textContent = s.title;
      const vis = visibleIndexes();
      const pos = vis.indexOf(current);
      lbCounter.textContent = `${pos + 1} / ${vis.length}`;
      preload(vis, pos);
    }

    function preload(vis: number[], pos: number) {
      [vis[pos - 1], vis[pos + 1]].forEach((idx) => {
        const s = slides[idx];
        if (!s) return;
        const img = new Image();
        img.srcset = s.srcset;
        img.src = s.src;
      });
    }

    function open(index: number, trigger: HTMLElement) {
      current = index;
      lastFocused = trigger;
      render();
      lb!.hidden = false;
      lb!.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      (root.querySelector('[data-lb-close-btn]') as HTMLElement)?.focus();
    }

    function close() {
      lb!.hidden = true;
      lb!.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      lbImg.removeAttribute('src');
      lbImg.removeAttribute('srcset');
      lastFocused?.focus();
    }

    function step(dir: number) {
      const vis = visibleIndexes();
      if (vis.length === 0) return;
      let pos = vis.indexOf(current);
      pos = (pos + dir + vis.length) % vis.length;
      current = vis[pos];
      render();
    }

    buttons.forEach((btn) =>
      btn.addEventListener('click', () =>
        open(Number(btn.dataset.index), btn),
      ),
    );
    root
      .querySelectorAll('[data-lb-close],[data-lb-close-btn]')
      .forEach((el) => el.addEventListener('click', close));
    root.querySelector('[data-lb-prev]')?.addEventListener('click', () => step(-1));
    root.querySelector('[data-lb-next]')?.addEventListener('click', () => step(1));

    // keyboard — only when this gallery's lightbox is open
    document.addEventListener('keydown', (e) => {
      if (lb!.hidden) return;
      switch (e.key) {
        case 'Escape':
          close();
          break;
        case 'ArrowLeft':
          step(-1);
          break;
        case 'ArrowRight':
          step(1);
          break;
        case 'Tab': {
          // simple focus trap within the dialog
          const focusable = Array.from(
            root.querySelectorAll<HTMLElement>('.lb-btn'),
          );
          if (focusable.length === 0) break;
          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          if (e.shiftKey && document.activeElement === first) {
            e.preventDefault();
            last.focus();
          } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
          break;
        }
      }
    });

    // basic swipe support on touch devices
    let touchX = 0;
    lb.addEventListener(
      'touchstart',
      (e) => (touchX = e.changedTouches[0].clientX),
      { passive: true },
    );
    lb.addEventListener(
      'touchend',
      (e) => {
        const dx = e.changedTouches[0].clientX - touchX;
        if (Math.abs(dx) > 50) step(dx < 0 ? 1 : -1);
      },
      { passive: true },
    );
  }

  document
    .querySelectorAll<HTMLElement>('[data-gallery]')
    .forEach((el) => initGallery(el));
</script>
